<%- include('partials/header') %>
    <div class="panel">
        <h2>Cadastrar Novo Cliente</h2>
        <form action="/clientes/novo" method="POST">
            <div class="form-grid">
                <div class="form-group">
                    <label>Nome do Cliente *</label>
                    <input type="text" name="nome_cli" required placeholder="Nome Completo" minlength="3">
                </div>
                <div class="form-group">
                    <label>E-mail</label>
                    <input type="email" name="email_cli" placeholder="nome@provedor.com">
                </div>
                <div class="form-group">
                    <label>Telefone de Contato</label>
                    <input type="text" name="telefone_cli" class="mask-telefone" placeholder="(00) 00000-0000" minlength="14">
                </div>
            </div>
            <button type="submit" class="btn btn-success" style="margin-top: 1.5rem;">Salvar Cliente</button>
        </form>
    </div>

    <div class="panel">
        <h2>Clientes Registrados</h2>
        <div class="table-responsive">
            <table class="tabela">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Telefone</th>
                        <th style="width: 100px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% clientes.forEach(cliente => { %>
                        <tr>
                            <td>#<%= cliente.id_cliente %></td>
                            <td><strong><%= cliente.nome_cli %></strong></td>
                            <td><%= cliente.email_cli || 'Não informado' %></td>
                            <td><%= cliente.telefone_cli || 'Não informado' %></td>
                            <td>
                                <form action="/clientes/deletar/<%= cliente.id_cliente %>" method="POST" onsubmit="return confirm('Confirmar exclusão definitiva do cliente?');">
                                    <button type="submit" class="btn btn-danger btn-table">Excluir</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
<%- include('partials/footer') %>