<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Acesso - Sistema ERP</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-wrapper">
    <div class="login-card">
        <h2>Acesso Corporativo</h2>
        
        <% if (erro) { %>
            <div class="alert alert-danger"><%= erro %></div>
        <% } %>

        <form action="/login" method="POST">
            <div class="form-group">
                <label>E-mail da Empresa</label>
                <input type="email" name="email" required>
            </div>
            <div class="form-group">
                <label>Senha Operacional</label>
                <input type="password" name="senha" required>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">Entrar</button>
        </form>
        <div style="text-align: center; margin-top: 1rem;">
            <a href="/cadastro">Registrar nova empresa</a>
        </div>
    </div>
</body>
</html>