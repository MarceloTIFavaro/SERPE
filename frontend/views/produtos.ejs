<%- include('partials/header') %>
    <div class="panel">
        <h2>Cadastrar Novo Produto em Estoque</h2>
        <form action="/produtos/novo" method="POST" class="form-grid">
            <div class="form-group">
                <label>Nome do Produto *</label>
                <input type="text" name="nome_prod" required placeholder="Ex: Mandioca">
            </div>
            <div class="form-group">
                <label>Preço de Venda (R$)</label>
                <input type="number" step="0.01" name="preco_venda" required placeholder="0.00">
            </div>
            <div class="form-group">
                <label>Custo do Produto (R$)</label>
                <input type="number" step="0.01" name="custo_prod" required placeholder="0.00">
            </div>
            <div class="form-group">
                <label>Quantidade Inicial</label>
                <input type="number" name="qnt_estoque" required placeholder="0">
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-success">Salvar Produto</button>
            </div>

        </form>
    </div>

    <div class="panel">
        <h2>Inventário de Produtos</h2>
        <div class="table-responsive">
            <table class="tabela">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome do Produto</th>
                        <th>Preço de Venda</th>
                        <th>Custo Fabril</th>
                        <th>Qtd. Estoque</th>
                        <th style="width: 100px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% produtos.forEach(prod=> { %>
                        <tr>
                            <td>#<%= prod.id_prod %>
                            </td>
                            <td><strong>
                                    <%= prod.nome_prod %>
                                </strong></td>
                            <td style="color: var(--success)">R$ <%= Number(prod.preco_venda).toFixed(2) %>
                            </td>
                            <td style="color: var(--text-muted)">R$ <%= Number(prod.custo_prod).toFixed(2) %>
                            </td>
                            <td>
                                <%= prod.qnt_estoque %> un
                            </td>
                            <td>
                                <form action="/produtos/deletar/<%= prod.id_prod %>" method="POST"
                                    onsubmit="return confirm('Deseja remover este item do catálogo?');">
                                    <button type="submit" class="btn btn-danger btn-table">Excluir</button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <%- include('partials/footer') %>