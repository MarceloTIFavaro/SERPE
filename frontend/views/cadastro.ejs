<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Registro - Sistema ERP</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-wrapper">
    <div class="login-card">
        <h2>Registrar Empresa</h2>
        
        <% if (erro) { %>
            <div class="alert alert-danger"><%= erro %></div>
        <% } %>

        <form action="/cadastro" method="POST">
            <div class="form-group" style="margin-bottom: 1rem;">
                <label>CNPJ *</label>
                <input type="text" name="cnpj" class="mask-cnpj" required placeholder="00.000.000/0000-00" minlength="18" value="<%= locals.dados?.cnpj || '' %>">
            </div>
            <div class="form-group" style="margin-bottom: 1rem;">
                <label>Nome da Empresa *</label>
                <input type="text" name="nome_emp" required placeholder="Sua Empresa LTDA" minlength="3" value="<%= locals.dados?.nome_emp || '' %>">
            </div>
            <div class="form-group" style="margin-bottom: 1rem;">
                <label>E-mail Corporativo *</label>
                <input type="email" name="email_emp" required placeholder="contato@empresa.com" value="<%= locals.dados?.email_emp || '' %>">
            </div>
            <div class="form-group" style="margin-bottom: 1rem;">
                <label>Telefone</label>
                <input type="text" name="telefone_emp" class="mask-telefone" placeholder="(00) 00000-0000" minlength="14" value="<%= locals.dados?.telefone_emp || '' %>">
            </div>
            <div class="form-group" style="margin-bottom: 1rem;">
                <label>Senha de Acesso *</label>
                <div class="password-wrapper">
                    <input type="password" name="senha" id="senha-cadastro" required placeholder="••••••••" minlength="6">
                    <button type="button" class="toggle-password" onclick="togglePassword('senha-cadastro', this)" title="Mostrar/Ocultar Senha">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    </button>
                </div>
            </div>
            <button type="submit" class="btn btn-success" style="width: 100%; margin-top: 1rem;">Finalizar Registro</button>
        </form>
        <div style="text-align: center; margin-top: 1.5rem;">
            <a href="/login" style="color: var(--accent); text-decoration: none; font-weight: 600;">Já possui conta? Fazer Login</a>
        </div>
    </div>
    <script src="https://unpkg.com/imask"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            IMask(document.querySelector('.mask-cnpj'), { mask: '00.000.000/0000-00' });
            IMask(document.querySelector('.mask-telefone'), { mask: '(00) 00000-0000' });
        });

        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const icon = button.querySelector('svg');
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
            } else {
                input.type = 'password';
                icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
            }
        }
    </script>
</body>
</html>