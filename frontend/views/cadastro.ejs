<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Registro - Sistema ERP</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-wrapper">
    <div class="login-card">
        <h2>Registrar Empresa</h2>
        
        <% if (erro) { %>
            <div class="alert alert-danger"><%= erro %></div>
        <% } %>

        <form action="/cadastro" method="POST">
            <div class="form-group">
                <label>CNPJ</label>
                <input type="text" name="cnpj" required>
            </div>
            <div class="form-group">
                <label>Nome da Empresa</label>
                <input type="text" name="nome_emp" required>
            </div>
            <div class="form-group">
                <label>Nome do Responsável</label>
                <input type="text" name="nome_resp">
            </div>
            <div class="form-group">
                <label>E-mail Corporativo</label>
                <input type="email" name="email_emp" required>
            </div>
            <div class="form-group">
                <label>Telefone</label>
                <input type="text" name="telefone_emp">
            </div>
            <div class="form-group">
                <label>Senha de Acesso</label>
                <input type="password" name="senha" required>
            </div>
            <button type="submit" class="btn btn-success" style="width: 100%; margin-top: 1rem;">Finalizar Registro</button>
        </form>
        <div style="text-align: center; margin-top: 1rem;">
            <a href="/login">Já possui conta? Fazer Login</a>
        </div>
    </div>
</body>
</html>